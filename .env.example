# ---------------------------------------------------------------------------
# TradePilot AI — environment configuration
# Copy this file to .env and adjust values. Never commit the real .env file.
# ---------------------------------------------------------------------------

# General
ENV=development

# Database
# Local/dev default (used automatically by apps/api if no .env is present):
#   sqlite:///./tradepilot.db
# Docker-compose overrides this to point at the postgres service:
DATABASE_URL=postgresql://tradepilot:tradepilot@localhost:5432/tradepilot

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# AI provider abstraction
# AI_PROVIDER=mock uses the built-in deterministic mock AI (no API key needed).
# AI_PROVIDER=openai requires OPENAI_API_KEY and routes through apps/api/app/services/ai_service.py
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Business defaults
DEFAULT_MARKUP_PERCENT=35
DEFAULT_MIN_MARGIN_PERCENT=15
DEFAULT_CURRENCY=KZT

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
