# ---------------------------------------------------------------------------
# TradePilot AI — environment configuration
# Copy this file to .env and adjust values. Never commit the real .env file.
# ---------------------------------------------------------------------------

# General
ENV=development

# Database
# Local/dev default - works with zero setup (sqlite file in this directory):
DATABASE_URL=sqlite:///./tradepilot.db
# For docker-compose this is overridden automatically to point at the postgres service.

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# AI provider abstraction
# AI_PROVIDER=mock uses the built-in deterministic mock AI (no API key needed).
# AI_PROVIDER=openai requires OPENAI_API_KEY and routes through apps/api/app/services/ai_service.py
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Business defaults
DEFAULT_MARKUP_PERCENT=35
DEFAULT_MIN_MARGIN_PERCENT=15
DEFAULT_CURRENCY=KZT

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
